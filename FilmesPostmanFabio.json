    {
      "name": "testeCaracteristicasFilme",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Verifica classificação indicativa\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const brasil = data.results.find(r => r.iso_3166_1 === \"BR\");\r",
              "\r",
              "    if (brasil) {\r",
              "        const cert = brasil.release_dates[0].certification;\r",
              "        console.log(\"Classificação no Brasil:\", cert);\r",
              "        pm.expect(cert).to.not.be.empty;\r",
              "    } else {\r",
              "        console.log(\"Classificação BR não disponível\");\r",
              "    }\r",
              "});\r",
              "\r",
              "// Visualização\r",
              "const data = pm.response.json();\r",
              "const filmeNome = pm.environment.get(\"filme_nome\");\r",
              "const brasil = data.results.find(r => r.iso_3166_1 === \"BR\");\r",
              "\r",
              "let template = `<h3>Classificação Indicativa — ${filmeNome}</h3>`;\r",
              "\r",
              "if (brasil) {\r",
              "    const cert = brasil.release_dates[0].certification || \"N/A\";\r",
              "    template += `<p><strong>Brasil:</strong> ${cert}</p>`;\r",
              "} else {\r",
              "    template += `<p>Classificação não disponível para o Brasil</p>`;\r",
              "}\r",
              "\r",
              "pm.visualizer.set(template);\r",
              "\r",
              "// Testes\r",
              "pm.test(\"Filme é classificação livre\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const brasil = data.results.find(r => r.iso_3166_1 === \"BR\");\r",
              "\r",
              "    if (brasil) {\r",
              "        const cert = brasil.release_dates[0].certification;\r",
              "        pm.expect(cert).to.eql(\"L\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Filme foi lançado em 2026\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const brasil = data.results.find(r => r.iso_3166_1 === \"BR\");\r",
              "\r",
              "    if (brasil) {\r",
              "        const ano = brasil.release_dates[0].release_date.substring(0, 4);\r",
              "        pm.expect(ano).to.eql(\"2026\");\r",
              "    }\r",
              "});\r",
              "\r",
              "pm.test(\"Filme foi lançado no Brasil antes dos EUA\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const brasil = data.results.find(r => r.iso_3166_1 === \"BR\");\r",
              "    const eua = data.results.find(r => r.iso_3166_1 === \"US\");\r",
              "    if (brasil && eua) {\r",
              "        const dataBR = new Date(brasil.release_dates[0].release_date);\r",
              "        const dataUS = new Date(eua.release_dates[0].release_date);\r",
              "        pm.expect(dataBR.getTime(), \"Brasil não recebeu o filme primeiro\").to.be.below(dataUS.getTime());\r",
              "    }\r",
              "});\r",
              "\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
