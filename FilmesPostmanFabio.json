    {
      "name": "testeFilmesFavoritos",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200\", function () {\r",
              "    pm.response.to.have.status(200);\r",
              "});\r",
              "\r",
              "pm.test(\"Retornou favoritos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.results).to.be.an(\"array\");\r",
              "    pm.expect(data.results.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Lista de nomes dos favoritos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const nomes = data.results.map(f => f.title);\r",
              "    console.log(\"Filmes favoritos:\", nomes);\r",
              "});\r",
              "\r",
              "// Visualização bonita na aba Visualize\r",
              "let template = `<h3>Filmes Favoritos</h3><ul>`;\r",
              "const data = pm.response.json();\r",
              "data.results.forEach(f => {\r",
              "    template += `<li>${f.title}</li>`;\r",
              "});\r",
              "template += `</ul>`;\r",
              "pm.visualizer.set(template);\r",
              "\r",
              "//Verificar se Clube da luta ta nos filmes favoritos da minha conta\r",
              "pm.test(\"Clube da Luta está nos favoritos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const encontrado = data.results.some(f => f.id === 550);\r",
              "    pm.expect(encontrado).to.be.true;\r",
              "});\r",
              "\r",
              "//Verificar se Barbie ta nos filmes favoritos da minha conta\r",
              "pm.test(\"Barbie está nos favoritos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const encontrado = data.results.some(f => f.id === 5346698);\r",
              "    pm.expect(encontrado).to.be.true;\r",
              "});\r",
              "\r",
              "pm.test(\"Todos os favoritos tem nota acima de 8\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const fracos = data.results.filter(f => f.vote_average < 8);\r",
              "\r",
              "    const lista = fracos.map(f => `${f.title} (nota: ${f.vote_average})`).join(\", \");\r",
              "    pm.expect(fracos.length, `Filmes com nota abaixo de 8: ${lista}`).to.eql(0);\r",
              "});\r",
              "\r",
              "pm.test(\"Todos os favoritos são do mesmo gênero\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const primeiroGenero = data.results[0].genre_ids[0];\r",
              "    data.results.forEach(f => {\r",
              "        pm.expect(f.genre_ids, `${f.title} não tem o mesmo gênero`).to.include(primeiroGenero);\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"Nenhum favorito tem mais de 20 anos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const anoLimite = new Date().getFullYear() - 20;\r",
              "    const antigos = data.results.filter(f => {\r",
              "        const ano = parseInt(f.release_date.substring(0, 4));\r",
              "        return ano <= anoLimite;\r",
              "    });\r",
              "\r",
              "    const lista = antigos.map(f => `${f.title} (${f.release_date.substring(0, 4)})`).join(\", \");\r",
              "    pm.expect(antigos.length, `Filmes velhos encontrados: ${lista}`).to.eql(0);\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
