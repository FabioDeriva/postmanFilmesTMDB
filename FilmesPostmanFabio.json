    {
      "name": "testesElencoFilme",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Retornou elenco\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.cast).to.be.an(\"array\");\r",
              "    pm.expect(data.cast.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "// Visualização dos 10 principais atores\r",
              "const data = pm.response.json();\r",
              "let template = `<h3>Elenco Principal</h3><table border=\"1\" cellpadding=\"8\" cellspacing=\"0\">`;\r",
              "template += `<tr><th>Ator</th><th>Personagem</th></tr>`;\r",
              "data.cast.slice(0, 10).forEach(a => {\r",
              "    template += `<tr><td>${a.name}</td><td>${a.character}</td></tr>`;\r",
              "});\r",
              "template += `</table>`;\r",
              "pm.visualizer.set(template);\r",
              "\r",
              "// === TESTES DO ELENCO ===\r",
              "pm.test(\"Ator principal é Ryan Gosling\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const principal = data.cast[0];\r",
              "    pm.expect(principal.name).to.eql(\"Ryan Gosling\");\r",
              "});\r",
              "\r",
              "pm.test(\"Ryan Gosling é literalmente eu\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const ryan = data.cast.find(a => a.name === \"Ryan Gosling\");\r",
              "    pm.expect(ryan.name, \"Infelizmente você não é o Ryan Gosling\").to.eql(\"Fábio\");\r",
              "});\r",
              "\r",
              "pm.test(\"Filme tem menos de 5 atores\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.cast.length).to.be.lessThan(5);\r",
              "});\r",
              "\r",
              "pm.test(\"Filme foi dirigido por um ator do elenco\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const diretor = data.crew.find(c => c.job === \"Director\");\r",
              "    const atores = data.cast.map(a => a.name);\r",
              "    pm.expect(atores, \"Diretor não atuou no próprio filme\").to.include(diretor.name);\r",
              "});\r",
              "\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
