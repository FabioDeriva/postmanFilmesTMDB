    {
      "name": "testeFilmeID",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Encontrou o filme\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.results.length).to.be.greaterThan(0);\r",
              "\r",
              "    const filme = data.results[0];\r",
              "    console.log(\"Filme:\", filme.title, \"| ID:\", filme.id);\r",
              "    pm.environment.set(\"filme_id\", filme.id);\r",
              "});\r",
              "\r",
              "// Visualização só com ID e nome\r",
              "let template = `<h3>Resultado da Busca</h3>`;\r",
              "const data = pm.response.json();\r",
              "if (data.results.length > 0) {\r",
              "    const filme = data.results[0];\r",
              "    const dataFormatada = filme.release_date.split(\"-\").reverse().join(\"/\");\r",
              "    template += `<p><strong>${filme.title}</strong> — ID: ${filme.id}</p>`;\r",
              "    template += `<p><strong>Lançamento:</strong> ${dataFormatada}</p>`;\r",
              "} else {\r",
              "    template += `<p>Nenhum filme encontrado</p>`;\r",
              "}\r",
              "pm.visualizer.set(template);\r",
              "\r",
              "//TESTE DE RELEVANCIA\r",
              "pm.test(\"Resultado é relevante pra busca\", function () {\r",
              "    const busca = pm.environment.get(\"filme_nome\").toLowerCase();\r",
              "    const filme = pm.response.json().results[0];\r",
              "    const relevante = filme.title.toLowerCase().includes(busca) ||\r",
              "                      filme.original_title.toLowerCase().includes(busca);\r",
              "    pm.expect(relevante, \"Primeiro resultado não parece relevante\").to.be.true;\r",
              "});\r",
              "\r",
              "//TESTES ESTRUTURA\r",
              "pm.test(\"Results é um array com resultados\", function () {\r",
              "    const data = pm.response.json();\r",
              "    pm.expect(data.results).to.be.an(\"array\");\r",
              "    pm.expect(data.results.length).to.be.greaterThan(0);\r",
              "});\r",
              "\r",
              "// === TESTE NEGATIVO ===\r",
              "pm.test(\"Nenhum resultado é adulto\", function () {\r",
              "    const data = pm.response.json();\r",
              "    data.results.forEach(f => {\r",
              "        pm.expect(f.adult).to.be.false;\r",
              "    });\r",
              "});\r",
              "\r",
              "pm.test(\"É o melhor filme de todos os tempos\", function () {\r",
              "    const data = pm.response.json();\r",
              "    const filme = data.results[0];\r",
              "    const ehMelhor = filme.original_title === \"The Lord of the Rings: The Return of the King\" ||\r",
              "                     filme.title === \"O Senhor dos Anéis: O Retorno do Rei\";\r",
              "    pm.expect(ehMelhor, `\"${filme.title}\"? infelizmente não estamos falando de O Senhor dos Anéis: O Retorno do Rei`).to.be.true;\r",
              "});\r",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
